---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatsBar from '../components/StatsBar.astro';
import SocialProof from '../components/SocialProof.astro';
import HomeCta from '../components/HomeCta.astro';
import { site } from '../data/site';
import { portfolioItems } from '../data/site';

const featuredWork = portfolioItems.filter((item) => !item.inProgress).slice(0, 3);
---

<BaseLayout
  title={site.name}
  description="UX researcher and human factors engineer with 25+ years of experience. Evidence-based research in safety-critical systems, enterprise SaaS, and product building."
  heroTitle="Building better products by combining cognitive science, rigorous research, and AI."
  wide
>
  <Fragment slot="after-hero">
    <StatsBar />
  </Fragment>

  <div class="intro-block">
    <h2>Hi, I'm JF!</h2>
    <p>
      I'm a cognitive scientist, UX researcher, and product builder who helps organizations make better product
      decisions. Over the past 25+ years, I've worked across aerospace, defense, enterprise software, and AI,
      combining rigorous research with practical product thinking to reduce uncertainty and improve user experiences.
    </p>
    <p>
      Today, I'm expanding that work by building AI-enabled products and workflows that accelerate research, support
      better decisions, and turn insights into action. Whether leading strategic research, developing new products, or
      experimenting with emerging technologies, my goal remains the same: helping teams build products people understand,
      trust, and value.
    </p>
    <HomeCta />
  </div>

  <SocialProof part="products" />

  <section class="featured-work">
    <h2 class="section-heading">Selected UX research work</h2>
    <div class="featured-work__grid">
      {
        featuredWork.map((item) => (
          <a class="featured-work__card" href={item.href}>
            <div class="featured-work__image">
              <img src={item.image} alt={item.imageAlt} loading="lazy" width="600" height="450" />
            </div>
            <div class="featured-work__text">
              <p class="featured-work__method">{item.subtitle}</p>
              <p class="featured-work__title">{item.title}</p>
            </div>
          </a>
        ))
      }
    </div>
    <p class="featured-work__more"><a href="/portfolio">View all work &rarr;</a></p>
  </section>

  <SocialProof part="experience" />
</BaseLayout>
