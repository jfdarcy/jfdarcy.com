---
import { homeStats } from '../data/home';
---

<section class="stats-bar" aria-label="Experience at a glance">
  <div class="stats-bar__inner">
    {
      homeStats.map((stat) => (
        <div class="stats-bar__item">
          <p class="stats-bar__value">{stat.value}</p>
          <p class="stats-bar__label">{stat.label}</p>
        </div>
      ))
    }
  </div>
</section>
