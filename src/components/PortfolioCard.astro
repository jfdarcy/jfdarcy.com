---
interface Props {
  title: string;
  subtitle: string;
  href: string;
  image: string;
  imageAlt: string;
  credit?: string;
  inProgress?: boolean;
  reverse?: boolean;
}

const { title, subtitle, href, image, imageAlt, credit, inProgress = false, reverse = false } = Astro.props;
---

<article class="portfolio-row" data-reverse={reverse}>
  <div class="portfolio-row__image">
    <img src={image} alt={imageAlt} loading="lazy" width="600" height="450" />
    {credit && <p class="photo-credit">{credit}</p>}
  </div>
  <div class="portfolio-row__text">
    <h2><a href={href}>{title}</a></h2>
    <p class="portfolio-row__subtitle">{subtitle}</p>
    {inProgress && <p class="portfolio-row__note">Case study in progress — details available upon request.</p>}
  </div>
</article>
